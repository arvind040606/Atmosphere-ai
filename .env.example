# ── WeatherAPI.com (required) ─────────────────────────────────────────────────
# Free key at https://www.weatherapi.com/signup.aspx
# Enables: city search, current weather, 10-day forecast, map click-to-fetch
VITE_WEATHER_API_KEY=ed1c7d3e8a1140edb91151424262106

# ── OpenWeatherMap (optional) ─────────────────────────────────────────────────
# Free key at https://openweathermap.org/api
# Enables: live weather tile overlays on the World Map (temp/rain/wind/clouds)
# Without this key the base map still works — you just won't see the overlays.
VITE_OWM_API_KEY=dc0a7efde28cef20a9ed674962c97216
